# SolarPro Global — Environment Variables
# Copy to .env.local for local development. NEVER commit real values.
# Production secrets go in Kubernetes Secrets or Render environment variables.

# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-python-secrets-token-hex-32
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite:///solar.db

# Neon PostgreSQL (production — use pooled connection string):
# DATABASE_URL=postgresql://user:pass@ep-example-pooler.us-east-2.aws.neon.tech/solarpro_db?sslmode=require

# Regional shards (Phase 3 — add when needed):
# DATABASE_URL_AF=postgresql://user:pass@ep-af.neon.tech/solarpro_af?sslmode=require
# DATABASE_URL_EU=postgresql://user:pass@ep-eu.neon.tech/solarpro_eu?sslmode=require
# DATABASE_URL_US=postgresql://user:pass@ep-us.neon.tech/solarpro_us?sslmode=require
# DATABASE_URL_ME=postgresql://user:pass@ep-me.neon.tech/solarpro_me?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:devpassword@localhost:6379/0
REDIS_PASSWORD=devpassword

# ── AI APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
GITHUB_MODELS_TOKEN=ghp_...

# ── Payments ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=support@aiappinvent.com
SMTP_PASS=your-email-password
SMTP_FROM=support@aiappinvent.com
EMAIL_SALES=sales@aiappinvent.com
EMAIL_SUPPORT=support@aiappinvent.com
EMAIL_BILLING=billing@aiappinvent.com
EMAIL_HELLO=sales@aiappinvent.com
EMAIL_PROPOSALS=sales@aiappinvent.com

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
GRAFANA_ADMIN_PASSWORD=SolarGrafana2026!
FLOWER_USER=admin
FLOWER_PASS=FlowerAdmin2026!

# ── Geo-Routing ──────────────────────────────────────────────────────────────
REGION=eu-west               # af-west | eu-west | us-east | me-central

# ── Kubernetes (CI/CD) ───────────────────────────────────────────────────────
# KUBECONFIG_DEV=base64-encoded-kubeconfig
# KUBECONFIG_STAGING=base64-encoded-kubeconfig
# KUBECONFIG_PRODUCTION=base64-encoded-kubeconfig

# ── Render ───────────────────────────────────────────────────────────────────
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_ID=srv-...
