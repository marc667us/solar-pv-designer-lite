# Sensitive
.env
*.db
*.db-shm
*.db-wal

# Logs
*.log
tunnel_*.log
flask_*.log
cf_*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Legacy desktop builds (not needed for web app)
dist/
dist2/
dist3/
build/
*.spec
*.zip

# Temp / editor
.vscode/
.idea/
*.tmp
Thumbs.db

# Backup files (created by binary patches + mojibake fixers)
*.bak
*.bak_*
*.bak.*

# Local curl / smoke-test artifacts (repo root only, not templates/)
/_check.html
/public_*.html
/upgrade_rendered.html

# Vault data + audit (created by docker-compose.vault.yml; sensitive)
vault-data/
vault-audit/

# Pair-coding review outputs (regenerated by scripts/quality-gate.sh; bulky)
reviews/*
!reviews/.gitkeep

# One-shot patch + debug scripts (moved from repo root 2026-06-08)
scripts/oneshot/
