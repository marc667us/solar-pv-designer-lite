# Copy to `.env` next to docker-compose.yml and fill in the secrets.
# .env is git-ignored on the operator side.

# 32+ hex chars; MUST match METRICS_BEARER on the Render Solar service.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SOLARPRO_METRICS_BEARER=

# Public base URL of the Solar app -- Prometheus scrapes <BASE>/metrics
SOLARPRO_BASE_URL=https://solarpro.aiappinvent.com

# Grafana admin login. Pick something long; this is the only initial
# bootstrap password.
GRAFANA_ADMIN_PASSWORD=

# Optional: rewrite Grafana root URL when fronted by a reverse proxy.
# Used for OIDC return URLs etc.
GRAFANA_ROOT_URL=http://localhost:3000
